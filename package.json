{
  "name": "fishStudio",
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "globals": "^17.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "turbo": "^2.7.2",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "**/*.{js,ts,jsx,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "packageManager": "bun@1.3.5",
  "private": true,
  "scripts": {
    "build": "dotenv -e .env -- turbo run build",
    "dev": "dotenv -e .env -- turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{js,ts,jsx,tsx,md,json}\"",
    "check-format": "prettier --check \"**/*.{js,ts,jsx,tsx,md,json}\"",
    "check-types": "turbo run check-types",
    "prepare": "husky",
    "db:setup": "cd packages/db && bun run db:setup",
    "db:migrate": "cd packages/db && bunx prisma db push",
    "db:seed": "cd packages/db && bun run db:seed"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@types/node": "^25.2.3"
  }
}
