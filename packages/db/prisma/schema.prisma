generator client {
  provider      = "prisma-client"
  output        = "../src/generated"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum ImageType {
  PRODUCT
  USER_AVATAR
  STORE_AVATAR
}

enum productStatus {
  Active
  Pending
  Draft
}

enum sellerEventType {
  FREE_DELIVERY
  DISCOUNT
  FLASH_SALE
}

model admins {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  name      String
  email     String           @unique
  password  String
  products  products[]
  coupons   discount_codes[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

//////////////////////////////////////////////////////
// IMAGES (NO BACK-RELATIONS TO USER / STORE)
//////////////////////////////////////////////////////

model images {
  id      String    @id @default(auto()) @map("_id") @db.ObjectId
  file_id String
  url     String
  type    ImageType @default(PRODUCT)

  // Link to Product
  productId String?   @db.ObjectId
  // Fix applied here to break the cycle
  product   products? @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  createdAt DateTime @default(now())
  users     users[]
  stores    stores[]

  @@index([productId])
}

//////////////////////////////////////////////////////
// USERS
//////////////////////////////////////////////////////

model users {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  phone_number String   @unique
  name         String
  following    String[]

  avatarId String? @db.ObjectId
  // Added NoAction here for safety
  avatar   images? @relation(fields: [avatarId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  storeReviews storeReviews[]
  favorites    favorites[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model discount_codes {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  public_name   String
  discountType  String
  discountValue Float
  discountCode  String   @unique
  sellerId      String?  @db.ObjectId
  adminId       String?  @db.ObjectId
  seller        sellers? @relation(fields: [sellerId], references: [id])
  admin         admins?  @relation(fields: [adminId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

//////////////////////////////////////////////////////
// SELLERS
//////////////////////////////////////////////////////

model sellers {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  email        String    @unique
  phone_number String
  password     String
  following    String[]
  banners      banners[]
  events       seller_events[]
  store        stores?
  coupons      discount_codes[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// STORES
//////////////////////////////////////////////////////

model stores {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String
  bio  String

  avatarId String? @db.ObjectId
  // Fix applied here to break the cycle
  avatar   images? @relation(fields: [avatarId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  address       String
  city          String
  pincode       String
  opening_hours String

  sellerId String  @unique @db.ObjectId
  seller   sellers @relation(fields: [sellerId], references: [id])

  products products[]

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  storeReviews storeReviews[]
}

//////////////////////////////////////////////////////
// STORE REVIEWS
//////////////////////////////////////////////////////

model storeReviews {
  id      String  @id @default(auto()) @map("_id") @db.ObjectId
  rating  Float
  reviews String?

  userId String @db.ObjectId
  user   users  @relation(fields: [userId], references: [id])

  storeId String? @db.ObjectId
  store   stores? @relation(fields: [storeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// FAVORITES
//////////////////////////////////////////////////////

model favorites {
  id        String @id @default(auto()) @map("_id") @db.ObjectId
  userId    String @db.ObjectId
  productId String @db.ObjectId

  user    users    @relation(fields: [userId], references: [id])
  product products @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

//////////////////////////////////////////////////////
// SITE CONFIG
//////////////////////////////////////////////////////

model site_config {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  categories    String[]
  subCategories Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("site_config")
}

//////////////////////////////////////////////////////
// PRODUCTS
//////////////////////////////////////////////////////

model products {
  id                   String @id @default(auto()) @map("_id") @db.ObjectId
  title                String
  slug                 String @unique
  category             String
  subCategory          String
  short_description    String
  detailed_description String

  images images[]

  tags         String[]
  sizes        String[]
  sizePricing  Json?
  cuttingTypes String[]
  pieceSizes   String[]

  processingWeightLoss String?
  stock                Int
  sale_price           Float
  regular_price        Float
  totalSold            Int         @default(0)
  favorites            favorites[]
  ratings              Float       @default(5)

  cashOnDelivery String?
  discount_codes String[]      @db.ObjectId
  status         productStatus @default(Active)
  isDeleted      Boolean?      @default(false)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  storeId String? @db.ObjectId
  store   stores? @relation(fields: [storeId], references: [id])
  adminId String? @db.ObjectId
  admin   admins? @relation(fields: [adminId], references: [id])

  catalogProductId String?    @db.ObjectId
  catalogProduct   products?  @relation("catalog_variants", fields: [catalogProductId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  storeVariants    products[] @relation("catalog_variants")

  @@index([catalogProductId])
}

model banners {
  id       String  @id @default(auto()) @map("_id") @db.ObjectId
  imageUrl String
  fileId   String
  isActive Boolean @default(true)

  // Link to Seller
  sellerId String  @db.ObjectId
  seller   sellers @relation(fields: [sellerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("banners")
}

model seller_events {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  sellerId    String          @db.ObjectId
  seller      sellers         @relation(fields: [sellerId], references: [id])
  title       String
  description String?
  type        sellerEventType
  minOrder    Float?
  discount    Float?
  startTime   DateTime
  endTime     DateTime
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([sellerId, startTime])
  @@map("seller_events")
}
