{
  "name": "@repo/db",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prisma:generate": "bunx prisma generate",
    "prisma:push": "bunx prisma db push",
    "prisma:seed": "bun run prisma/seed.ts",
    "db:setup": "bun run prisma:generate && bun run prisma:push && bun run prisma:seed"
  },
  "dependencies": {
    "@prisma/client": "6",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "prisma": "6",
    "@repo/env-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
