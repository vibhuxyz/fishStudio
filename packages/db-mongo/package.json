{
  "name": "@repo/db-mongo",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declaration --declarationMap false --outDir dist --project tsconfig.json",
    "dev": "tsup --watch",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "@types/bcryptjs": "^3.0.0",
    "bcryptjs": "^3.0.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "prisma": "^5.14.0",
    "tsup": "^8.5.0",
    "typescript": "^5.4.5"
  },
  "prisma": {
    "seed": "bun src/seed.ts"
  }
}
