{
  "name": "@repo/error-handlers",
  "type": "module",
  "private": true,
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsup src/main.ts --format esm --dts",
    "dev": "tsup src/main.ts --format esm --dts --watch"
  },
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "default": "./dist/main.js"
    }
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@repo/typescript-config": "workspace:*",
    "tsup": "^8.5.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@types/express": "^5.0.6",
    "express": "^5.2.1"
  }
}
