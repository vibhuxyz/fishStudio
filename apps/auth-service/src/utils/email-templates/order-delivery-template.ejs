<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; line-height: 1.6; color: #333; margin: 0; padding: 0; }
        .container { max-width: 600px; margin: 20px auto; padding: 20px; border: 1px solid #e2e8f0; border-radius: 8px; }
        .header { background: #0f172a; color: #ffffff; padding: 24px; text-align: center; border-radius: 6px 6px 0 0; }
        .status-badge { display: inline-block; background: #10b981; color: white; padding: 4px 12px; border-radius: 9999px; font-size: 12px; font-weight: bold; margin-top: 8px; }
        .content { padding: 32px 24px; }
        .order-summary { width: 100%; border-collapse: collapse; margin-top: 24px; }
        .order-summary th { text-align: left; padding: 12px; border-bottom: 2px solid #f1f5f9; color: #64748b; font-size: 13px; text-transform: uppercase; }
        .order-summary td { padding: 12px; border-bottom: 1px solid #f1f5f9; font-size: 14px; }
        .total-row { background: #f8fafc; font-weight: bold; }
        .address-box { background: #fffbeb; border: 1px solid #fef3c7; padding: 16px; border-radius: 8px; margin-top: 24px; }
        .footer { font-size: 12px; color: #94a3b8; text-align: center; padding: 24px; border-top: 1px solid #f1f5f9; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1 style="margin:0; font-size: 20px;"><%= ORG_NAME %></h1>
            <div class="status-badge">ORDER DELIVERED</div>
        </div>
        <div class="content">
            <p style="font-size: 16px; font-weight: 500;">Hi <%= name %>,</p>
            <p><%= message %></p>
            
            <h3 style="margin-top: 32px; font-size: 16px; border-left: 4px solid #0f172a; padding-left: 12px;">Order Details</h3>
            <table class="order-summary">
                <thead>
                    <tr>
                        <th>Item</th>
                        <th style="text-align: center;">Qty</th>
                        <th style="text-align: right;">Price</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (metadata && metadata.items && metadata.items.length > 0) { %>
                        <% metadata.items.forEach(function(item) { %>
                            <tr>
                                <td><%= item.name %></td>
                                <td style="text-align: center;"><%= item.quantity %></td>
                                <td style="text-align: right;">₹<%= item.price.toFixed(2) %></td>
                            </tr>
                        <% }); %>
                    <% } %>
                    <tr class="total-row">
                        <td colspan="2" style="text-align: right; padding: 16px;">Total Amount Paid</td>
                        <td style="text-align: right; padding: 16px; color: #0f172a;">₹<%= metadata.totalAmount.toFixed(2) %></td>
                    </tr>
                </tbody>
            </table>

            <div class="address-box">
                <h4 style="margin: 0 0 8px 0; color: #92400e; font-size: 13px; text-transform: uppercase;">Delivered To</h4>
                <p style="margin: 0; font-size: 14px; color: #78350f;">
                    <strong><%= metadata.deliveryName || name %></strong><br>
                    <%= metadata.deliveryAddress %><br>
                    <%= metadata.deliveryCity %>, <%= metadata.deliveryPincode %>
                </p>
            </div>
            
            <p style="margin-top: 32px; font-size: 13px; color: #64748b;">
                Thank you for choosing <%= ORG_NAME %>! We hope you enjoy your purchase.
            </p>
        </div>
        <div class="footer">
            <p>&copy; 2026 <%= ORG_NAME %>. All rights reserved.</p>
            <p>Contact us at: <%= ORG_EMAIL %></p>
        </div>
    </div>
</body>
</html>
