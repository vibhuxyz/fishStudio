{
  "cli": {
    "version": ">= 18.13.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://fish-api.ddns.net",
        "EXPO_PUBLIC_SERVER_URI": "https://fish-api.ddns.net",
        "EXPO_PUBLIC_CHATTING_WEBSOCKET_URI": "wss://fish-api.ddns.net"
      }
    },
    "preview-compact": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "ORG_GRADLE_PROJECT_reactNativeArchitectures": "arm64-v8a",
        "EXPO_PUBLIC_API_URL": "https://fish-api.ddns.net",
        "EXPO_PUBLIC_SERVER_URI": "https://fish-api.ddns.net",
        "EXPO_PUBLIC_CHATTING_WEBSOCKET_URI": "wss://fish-api.ddns.net"
      }
    },
    "preview-aab": {
      "distribution": "internal",
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://fish-api.ddns.net",
        "EXPO_PUBLIC_SERVER_URI": "https://fish-api.ddns.net",
        "EXPO_PUBLIC_CHATTING_WEBSOCKET_URI": "wss://fish-api.ddns.net"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://fish-api.ddns.net",
        "EXPO_PUBLIC_SERVER_URI": "https://fish-api.ddns.net",
        "EXPO_PUBLIC_CHATTING_WEBSOCKET_URI": "wss://fish-api.ddns.net"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
