# API Gateway URL (same as user-ui)
# Primary: EXPO_PUBLIC_API_URL, Fallback: EXPO_PUBLIC_SERVER_URI, Default: http://localhost:8080
EXPO_PUBLIC_SERVER_URI=http://localhost:8080

# WebSocket URL for real-time messaging (worker service)
EXPO_PUBLIC_CHATTING_WEBSOCKET_URI=ws://localhost:6006

# ImageKit private key for image optimization (optional)
EXPO_PUBLIC_IMAGEKIT_PRIVATE_KEY=

# Stripe publishable key for payments
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=
