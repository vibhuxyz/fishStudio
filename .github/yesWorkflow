name: Deploy FishStudio to Production
on:
  push:
    branches:
      - main

jobs:
  build-and-push:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Login to Docker Hub
        uses: docker/login-action@v3
        with:
          username: ${{ secrets.DOCKER_USERNAME }}
          password: ${{ secrets.DOCKER_PASSWORD }}

      - name: Build and Push Microservices
        run: |
          docker build -f docker/api-gateway/Dockerfile -t ${{ secrets.DOCKER_USERNAME }}/api-gateway:prod .
          docker build -f docker/auth-service/Dockerfile -t ${{ secrets.DOCKER_USERNAME }}/auth-service:prod .
          docker build -f docker/product-service/Dockerfile -t ${{ secrets.DOCKER_USERNAME }}/product-service:prod .
          docker build -f docker/order-service/Dockerfile -t ${{ secrets.DOCKER_USERNAME }}/order-service:prod .
          docker build -f docker/notification-service/Dockerfile -t ${{ secrets.DOCKER_USERNAME }}/notification-service:prod .
          docker build -f docker/worker-service/Dockerfile -t ${{ secrets.DOCKER_USERNAME }}/worker-service:prod .

          docker push ${{ secrets.DOCKER_USERNAME }}/api-gateway:prod
          docker push ${{ secrets.DOCKER_USERNAME }}/auth-service:prod
          docker push ${{ secrets.DOCKER_USERNAME }}/product-service:prod
          docker push ${{ secrets.DOCKER_USERNAME }}/order-service:prod
          docker push ${{ secrets.DOCKER_USERNAME }}/notification-service:prod
          docker push ${{ secrets.DOCKER_USERNAME }}/worker-service:prod
